{
  "buildCommand": "echo 'Static site - no build needed'",
  "devCommand": "python3 -m http.server 3000",
  "env": {},
  "cleanUrls": true,
  "headers": [
    {
      "source": "(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "outputDirectory": "."
}
